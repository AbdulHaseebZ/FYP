{
  "inverter_model": "TSUN TSOL-MS300~800 | 2 MPPT | Microinverter",
  "protocol_reference": "https://github.com/davidrapan/ha-solarman/issues/153",
  "categories": [
    {
      "category": "Power",
      "parameters": [
        { "name": "PV Power 1", "register": "0x3012", "scaling": 0.1, "unit": "W" },
        { "name": "PV Power 2", "register": "0x3015", "scaling": 0.1, "unit": "W" },
        { "name": "Today Production", "register": "0x301c", "scaling": 0.01, "unit": "kWh" },
        { "name": "Today Production 1", "register": "0x301f", "scaling": 0.1, "unit": "kWh" },
        { "name": "Today Production 2", "register": "0x3022", "scaling": 0.01, "unit": "kWh" },
        { "name": "Total Production", "register": "0x301e", "scaling": 0.01, "unit": "kWh" },
        { "name": "PV Max Power", "register": "0x2007", "scaling": 1, "unit": "W" },
        { "name": "Rated Power", "register": "0x300e", "scaling": 1, "unit": "W" },
        { "name": "Output Power", "register": "0x300f", "scaling": 0.1, "unit": "W" }
      ]
    },
    {
      "category": "Voltage",
      "parameters": [
        { "name": "PV Voltage 1", "register": "0x3010", "scaling": 0.1, "unit": "V" },
        { "name": "PV Voltage 2", "register": "0x3013", "scaling": 0.1, "unit": "V" },
        { "name": "Grid Voltage", "register": "0x3009", "scaling": 0.1, "unit": "V" }
      ]
    },
    {
      "category": "Current",
      "parameters": [
        { "name": "PV Current 1", "register": "0x3011", "scaling": 0.01, "unit": "A" },
        { "name": "PV Current 2", "register": "0x3014", "scaling": 0.01, "unit": "A" },
        { "name": "Grid Current", "register": "0x300a", "scaling": 0.01, "unit": "A" }
      ]
    },
    {
      "category": "Temperature",
      "parameters": [
        { "name": "Temperature", "register": "0x300c", "scaling": 1, "offset": 40, "unit": "°C" }
      ]
    },
    {
      "category": "Frequency",
      "parameters": [
        { "name": "Grid Frequency", "register": "0x300b", "scaling": 0.01, "unit": "Hz" }
      ]
    }
  ]
}