{
  "inverter_model": "Sofar G3 | Three Phase | Hybrid Inverter",
  "protocol_reference": "https://github.com/user-attachments/files/18220633/SOFAR_Modbus_Protocol_English_G3_V1.22.only.3PH.xlsx",
  "categories": [
    {
      "category": "Power",
      "parameters": [
        { "name": "PV Power", "register": "0x05C4", "scaling": 100, "unit": "W"},
        { "name": "Battery Power", "register": "0x0606", "scaling": 10, "unit": "W"},
        { "name": "Total Active Power", "register": "0x0485", "scaling": 10, "unit": "W"},
        { "name": "Total PCC Active Power", "register": "0x0488", "scaling": 10, "unit": "W"},
        { "name": "Phase 1 power", "register": "0x048F", "scaling": 10, "unit": "W"},
        { "name": "Phase 2 Power", "register": "0x049A", "scaling": 10, "unit": "W"},
        { "name": "Phase 3 Power", "register": "0x04A5", "scaling": 10, "unit": "W"},
        { "name": "External Power", "register": "0x04AF", "scaling": 10, "unit": "W"},
        { "name": "Today Power Production", "register": "0x0684", "scaling": 0.01, "unit": "kWh", "size": 2},
        { "name": "Total Power Production", "register": "0x0686", "scaling": 0.1, "unit": "kWh", "size": 2},
        { "name": "Today Load Power", "register": "0x0688", "scaling": 0.01, "unit": "kWh", "size": 2},
        { "name": "Total Load Power", "register": "0x068A", "scaling": 0.1, "unit": "kWh", "size": 2},
        { "name": "Today Energy Import", "register": "0x068C", "scaling": 0.01, "unit": "kWh", "size": 2},
